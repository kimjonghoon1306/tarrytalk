{
  "rules": {
    ".read": false,
    ".write": false,
    "users": {
      ".read": "auth != null",
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('isAdmin').val() === true || auth.token.email === 'tarry9653@daum.net')",
        "displayName": {
          ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 50"
        },
        "email": {
          ".validate": "newData.isString()"
        },
        "isAdmin": {
          ".validate": "newData.val() === false || auth.token.email === 'tarry9653@daum.net'"
        },
        "disabled": {
          ".validate": "(auth.uid === $uid && !data.exists() && newData.val() === false) || root.child('users').child(auth.uid).child('isAdmin').val() === true || auth.token.email === 'tarry9653@daum.net'"
        },
        "mutedUntil": {
          ".validate": "auth.token.email === 'tarry9653@daum.net' || root.child('users').child(auth.uid).child('isAdmin').val() === true"
        },
        "warnings": {
          ".validate": "auth.token.email === 'tarry9653@daum.net' || root.child('users').child(auth.uid).child('isAdmin').val() === true"
        },
        "friends": {
          ".write": "auth != null && auth.uid === $uid"
        },
        "fcmTokens": {
          ".write": "auth != null && auth.uid === $uid",
          "$token": {
            ".validate": "auth != null && auth.uid === $uid && (newData.val() === true || !newData.exists())"
          }
        }
      }
    },
    "rooms": {
      ".read": "auth != null",
      "$roomId": {
        ".read": "auth != null && (data.child('members').child(auth.uid).exists() || root.child('users').child(auth.uid).child('isAdmin').val() === true || auth.token.email === 'tarry9653@daum.net')",
        ".write": "auth != null && ((!data.exists() && newData.exists()) || (!newData.exists() && (data.child('createdBy').val() === auth.uid || root.child('users').child(auth.uid).child('isAdmin').val() === true || auth.token.email === 'tarry9653@daum.net')))",
        "members": {
          "$uid": {
            ".write": "auth != null && ((!newData.exists() && data.exists() && auth.uid === $uid) || root.child('rooms').child($roomId).child('createdBy').val() === auth.uid || root.child('users').child(auth.uid).child('isAdmin').val() === true || auth.token.email === 'tarry9653@daum.net')",
            ".validate": "newData.val() === true || !newData.exists()"
          }
        },
        "unread": {
          "$uid": {
            ".write": "auth != null && (root.child('rooms').child($roomId).child('members').child(auth.uid).exists() || root.child('users').child(auth.uid).child('isAdmin').val() === true || auth.token.email === 'tarry9653@daum.net') && (auth.uid === $uid || root.child('rooms').child($roomId).child('members').child($uid).exists())",
            ".validate": "newData.isNumber() || !newData.exists()"
          }
        },
        "pinned": {
          ".write": "auth != null && (root.child('rooms').child($roomId).child('createdBy').val() === auth.uid || root.child('users').child(auth.uid).child('isAdmin').val() === true || auth.token.email === 'tarry9653@daum.net')"
        },
        "lastMsg": {
          ".write": "auth != null && (root.child('rooms').child($roomId).child('members').child(auth.uid).exists() || root.child('users').child(auth.uid).child('isAdmin').val() === true || auth.token.email === 'tarry9653@daum.net')"
        },
        "lastAt": {
          ".write": "auth != null && (root.child('rooms').child($roomId).child('members').child(auth.uid).exists() || root.child('users').child(auth.uid).child('isAdmin').val() === true || auth.token.email === 'tarry9653@daum.net')"
        },
        "suspendedUntil": {
          ".write": "auth != null && (root.child('rooms').child($roomId).child('createdBy').val() === auth.uid || root.child('users').child(auth.uid).child('isAdmin').val() === true || auth.token.email === 'tarry9653@daum.net')"
        }
      }
    },
    "messages": {
      "$roomId": {
        ".read": "auth != null && (root.child('rooms').child($roomId).child('members').child(auth.uid).exists() || root.child('users').child(auth.uid).child('isAdmin').val() === true || auth.token.email === 'tarry9653@daum.net')",
        "$msgId": {
          ".write": "auth != null && ((!data.exists() && newData.exists() && (root.child('rooms').child($roomId).child('members').child(auth.uid).exists() || root.child('users').child(auth.uid).child('isAdmin').val() === true || auth.token.email === 'tarry9653@daum.net') && (newData.child('uid').val() === auth.uid || newData.child('uid').val() === 'system')) || (data.exists() && newData.exists() && (data.child('uid').val() === auth.uid || root.child('users').child(auth.uid).child('isAdmin').val() === true || auth.token.email === 'tarry9653@daum.net')) || (data.exists() && !newData.exists() && (data.child('uid').val() === auth.uid || root.child('users').child(auth.uid).child('isAdmin').val() === true || auth.token.email === 'tarry9653@daum.net')))",
          "text": {
            ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 5000)"
          },
          "type": {
            ".validate": "newData.isString() && newData.val().matches(/^(text|image|video|document|schedule|system|sticker|poll|voice)$/)"
          },
          "at": {
            ".validate": "newData.isNumber()"
          },
          "reactions": {
            "$emoji": {
              "$uid": {
                ".write": "auth != null && auth.uid === $uid && root.child('rooms').child($roomId).child('members').child(auth.uid).exists()",
                ".validate": "newData.isBoolean() || !newData.exists()"
              }
            }
          },
          "readBy": {
            "$uid": {
              ".write": "auth != null && auth.uid === $uid && root.child('rooms').child($roomId).child('members').child(auth.uid).exists()",
              ".validate": "newData.isBoolean() || !newData.exists()"
            }
          }
        }
      }
    },
    "typing": {
      "$roomId": {
        ".read": "auth != null && root.child('rooms').child($roomId).child('members').child(auth.uid).exists()",
        "$uid": {
          ".write": "auth != null && auth.uid === $uid && root.child('rooms').child($roomId).child('members').child(auth.uid).exists()",
          ".validate": "!newData.exists() || (newData.hasChildren(['active','at']) && newData.child('active').isBoolean() && newData.child('at').isNumber())"
        }
      }
    },
    "notices": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('isAdmin').val() === true || auth.token.email === 'tarry9653@daum.net')"
    },
    "announcements": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('isAdmin').val() === true || auth.token.email === 'tarry9653@daum.net')"
    },
    "ads": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('isAdmin').val() === true || auth.token.email === 'tarry9653@daum.net')",
      "$adId": {
        "views": {
          ".write": "auth != null"
        },
        "clicks": {
          ".write": "auth != null"
        }
      }
    },
    "popup": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('isAdmin').val() === true || auth.token.email === 'tarry9653@daum.net')"
    },
    "welcome": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('isAdmin').val() === true || auth.token.email === 'tarry9653@daum.net')"
    }
  }
}